%% 11-config-flow.mmd — mahin movie config [get|set] [key] [value]
%% Version: 1.1.0 | Updated: 2026-04-06

flowchart TD
    A([movie config args]) --> B{Args provided?}
    B -->|no| C[Show all config keys]
    B -->|yes| D{Action?}

    D -->|get| E{Key provided?}
    D -->|set| F{Key + value provided?}
    D -->|other| G[/Error: Unknown action/]

    E -->|no| H[/Error: Usage get key/]
    E -->|yes| I[GetConfig key from DB]
    I --> J{Found?}
    J -->|yes| K[/Display key = value/]
    J -->|no| L[/Display key = not set/]

    F -->|no| M[/Error: Usage set key value/]
    F -->|yes| N[SetConfig key value in DB]
    N --> O{Success?}
    O -->|yes| P[/Display key = value confirmed/]
    O -->|no| Q[/Error message/]

    C --> R[Iterate known keys]
    R --> S{Key is tmdb_api_key\nand len > 8?}
    S -->|yes| T[Mask: first4...last4]
    S -->|no| U[Show raw value or not set]
    T --> V[Display formatted row]
    U --> V
    V --> W{More keys?}
    W -->|yes| R
    W -->|no| X([Done])

    classDef entryExit fill:#1e293b,stroke:#1e293b,color:#f1f5f9,stroke-width:2px
    classDef process fill:#f1f5f9,stroke:#cbd5e1,color:#1e293b
    classDef decision fill:#e2e8f0,stroke:#94a3b8,color:#1e293b
    classDef success fill:#22c55e,stroke:#16a34a,color:#ffffff
    classDef error fill:#ef4444,stroke:#dc2626,color:#ffffff
    classDef warning fill:#f59e0b,stroke:#d97706,color:#ffffff
    classDef info fill:#3b82f6,stroke:#2563eb,color:#ffffff
    classDef prompt fill:#8b5cf6,stroke:#7c3aed,color:#ffffff

    class A,X entryExit
    class C,I,N,R,T,U,V process
    class B,D,E,F,J,O,S,W decision
    class K,P success
    class G,H,M,Q error
    class L warning
